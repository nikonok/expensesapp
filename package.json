  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@tailwindcss/vite": "4.2.2",
    "date-fns": "4.1.0",
    "dexie": "4.4.1",
    "dexie-react-hooks": "^4.4.0",
    "i18next": "26.0.1",
    "lucide-react": "1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "17.0.1",
    "react-router": "7.13.2",
    "recharts": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vite-plugin-pwa": "1.2.0",
    "workbox-window": "7.4.0",
    "xlsx": "0.18.5",
    "zod": "4.3.6",
    "zustand": "5.0.12"
