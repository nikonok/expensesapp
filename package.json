    "@vitejs/plugin-react": "latest",
    "eslint": "10.1.0",
    "fake-indexeddb": "latest",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "vitest": "4.1.2"
  }
